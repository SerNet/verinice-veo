{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeAll",
    ":automergePr"
  ],
  "reviewers": [
    "jj",
    "jk",
    "uz"
  ],
  "assignAutomerge": true,
  "packageRules": [
    {
      "groupName": "Spotless",
      "postUpgradeTasks": {
        "commands": [
          "./gradlew spotlessApply"
        ],
        "fileFilters": [
          "**/*"
        ]
      },
      "matchPackageNames": [
        "/^com.diffplug.spotless/"
      ]
    },
    {
      "groupName": "Springdoc",
      "matchPackageNames": [
        "/^org.springdoc:/"
      ]
    },
    {
      "groupName": "JSON Schema Generator",
      "matchPackageNames": [
        "/^com.github.victools:jsonschema/"
      ]
    },
    {
      "groupName": "Swagger",
      "matchPackageNames": [
        "/^io.swagger.core.v3:/"
      ]
    },
    {
      "groupName": "JWT",
      "matchPackageNames": [
        "/^io.jsonwebtoken:/"
      ]
    },
    {
      "matchPackageNames": [
        "eclipse-temurin"
      ],
      "allowedVersions": "25-jdk"
    },
    {
      "groupName": "JGraphT",
      "matchPackageNames": [
        "/^org.jgrapht:/"
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "**/src/*/resources/application*.*"
      ],
      "matchStrings": [
        "jdbc:tc:postgresql:(?<currentValue>[a-zA-Z0-9.-]+):"
      ],
      "depNameTemplate": "postgres",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "misc/scripts/runPostgres.sh"
      ],
      "matchStrings": [
        "\\n\\s*postgresql:(?<currentValue>[a-zA-Z0-9.-]+)\\s*\\n"
      ],
      "depNameTemplate": "postgres",
      "datasourceTemplate": "docker"
    }
  ]
}
